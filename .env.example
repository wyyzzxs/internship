# ============================================================
# AI 智能旅游规划师 · .env.example
# 复制本文件为 .env,填入真实 Key
# 命令: cp .env.example .env(Windows: copy .env.example .env)
# ⚠️  .env 不要提交到 Git(已在 .gitignore 中)
# ============================================================

# ===== 阿里云百炼(DashScope)— 必填 =====
# 每个组员申请自己的,免费:https://bailian.console.aliyun.com/
# 注册 → 开通 DashScope → 创建 API Key
DASHSCOPE_API_KEY=sk-请填你的Key

# ===== 和风天气 API — 选填 =====
# 没有就留空,自动用 ./data/weather_cache.json 静态数据
# 免费申请:https://console.qweather.com/
QWEATHER_API_KEY=
# 和风新版控制台如果提示 API Host,填完整地址,例如 https://xxxx.qweatherapi.com
# 老版 Key 可留空,默认使用 geoapi.qweather.com / devapi.qweather.com
QWEATHER_API_HOST=

# ===== 高德地图 JS API — 必填 =====
# 注意要申请"Web 端 JS API"类型,不是"Web 服务"
# 申请:https://lbs.amap.com/ → 应用管理 → 添加 Key → 选"Web 端(JS API)"
AMAP_JS_API_KEY=a21b11bac5ca4b628088bc1ac251aa94

# ===== 高德 Web 服务 API — 选填 =====
# 周边 POI 搜索如果要查真实餐厅/酒店/厕所,建议额外申请"Web服务" Key
# 没有就留空,自动使用 ./data/restaurants.json / hotels.json / attractions.json
AMAP_WEB_SERVICE_KEY=

# ===== 应用配置 =====
APP_ENV=development
DEBUG=true

# ===== Mock 模式开关(没 Key 时自动开) =====
# true = 用本地假数据,不需要 API Key
# false = 用真实 API(默认)
MOCK_LLM=false
MOCK_WEATHER=false

# ===== 服务端口 =====
BACKEND_PORT=8000
FRONTEND_PORT=8501
